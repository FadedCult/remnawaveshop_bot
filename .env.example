# App
APP_NAME=RemnaShop
ENVIRONMENT=dev
BASE_URL=https://bot.example.com
TIMEZONE=Europe/Moscow

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/remnashop.db

# Telegram
BOT_TOKEN=change-me
BOT_ADMIN_IDS=123456789
SUPPORT_USERNAME=your_support_username

# Admin panel auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Optional alternative to ADMIN_PASSWORD:
# ADMIN_PASSWORD_HASH=$2b$12$...
SESSION_SECRET=change-me-session-secret

# Web
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_DOMAIN=panel.example.com

# Remnawave API
REMNAWAVE_BASE_URL=https://remnawave.example.com/api/v1
REMNAWAVE_API_KEY=change-me
REMNAWAVE_TIMEOUT=20
REMNAWAVE_USERS_PATH=/users
REMNAWAVE_SUBSCRIPTIONS_PATH=/subscriptions
REMNAWAVE_SERVERS_PATH=/servers
REMNAWAVE_NODES_PATH=/nodes
REMNAWAVE_STATS_PATH=/stats

# Payments integration placeholders
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Backups
BACKUP_DIR=./backups
